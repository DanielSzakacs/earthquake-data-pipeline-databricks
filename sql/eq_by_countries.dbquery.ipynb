   "source": [
    "SELECT\n",
    "  COALESCE(country_code, 'Unknown') AS country_code,\n",
    "  COUNT(*) AS earthquake_count\n",
    "FROM gold_earthquake_dashboard_vw\n",
    "GROUP BY COALESCE(country_code, 'Unknown')\n",
    "ORDER BY earthquake_count DESC\n",
    "LIMIT 10;"
